{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "."
  },
  "exclude": [
    "node_modules",
    ".expo",
    "dist",
    "web-build"
  ],
  "paths": {
    "@/*": [
      "./src/*"
    ],
    "@/consts": [
      "./src/consts"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}